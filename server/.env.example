# ──────────────────────────────────────────────
# StayFinder Server — Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# Database — PostgreSQL (Neon/Supabase/Railway free tier)
# Get a free PostgreSQL database at: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/stayfinder?sslmode=require"

# JWT Secrets — MUST be changed in production (use: openssl rand -hex 64)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# JWT Expiry
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated allowed origins
CLIENT_URL="http://localhost:5173"

# Email — Resend (https://resend.com)
# Get your free API key from https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL="StayFinder <onboarding@resend.dev>"

# Cloudinary — Image uploads (https://cloudinary.com)
# Get credentials from Dashboard > Settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe — Payments (https://stripe.com)
# Get test keys from Developers > API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry — Error Monitoring (https://sentry.io)
SENTRY_DSN=

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
